# "Chat with Jaypee" AI assistant configuration.
# Copy this file to .env.local for local dev (run with `vercel dev`),
# and add the same variables in your Vercel project: Settings > Environment Variables.

# Required. Get a FREE Gemini key at https://aistudio.google.com/apikey
CHAT_API_KEY=your_api_key_here

# Google Gemini (OpenAI-compatible endpoint).
CHAT_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
CHAT_MODEL=gemini-2.5-flash

# To use OpenAI instead:
# CHAT_API_URL=https://api.openai.com/v1/chat/completions
# CHAT_MODEL=gpt-4o-mini

# To use Groq instead (free):
# CHAT_API_URL=https://api.groq.com/openai/v1/chat/completions
# CHAT_MODEL=llama-3.3-70b-versatile

# "Schedule a Call" auto-emailing via Web3Forms (free).
# Get a key at https://web3forms.com (enter your email). Safe to expose on the client.
# Without this, the form falls back to opening the visitor's email app.
VITE_WEB3FORMS_KEY=your_web3forms_access_key
